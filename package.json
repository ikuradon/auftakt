{
  "name": "@ikuradon/auftakt",
  "version": "0.0.1",
  "description": "Reactive event store for rx-nostr with NIP semantics",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./backends/memory": {
      "types": "./dist/backends/memory.d.ts",
      "import": "./dist/backends/memory.js"
    },
    "./backends/indexeddb": {
      "types": "./dist/backends/indexeddb.d.ts",
      "import": "./dist/backends/indexeddb.js"
    },
    "./sync": {
      "types": "./dist/sync/index.d.ts",
      "import": "./dist/sync/index.js"
    },
    "./backends/cached": {
      "types": "./dist/backends/cached.d.ts",
      "import": "./dist/backends/cached.js"
    },
    "./adapters/svelte": {
      "types": "./dist/adapters/svelte.d.ts",
      "import": "./dist/adapters/svelte.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && oxlint src/",
    "format": "oxfmt --write src/ tests/",
    "format:check": "oxfmt --check src/ tests/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "rx-nostr": "^3.0.0",
    "rxjs": "^7.8.0"
  },
  "dependencies": {
    "nostr-typedef": "^0.13.0"
  },
  "devDependencies": {
    "@ikuradon/tsunagiya": "^0.4.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "fake-indexeddb": "^6.0.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "rx-nostr": "^3.6.0",
    "rxjs": "^7.8.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ikuradon/auftakt"
  },
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  }
}
